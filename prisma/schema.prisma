model User {
  id                 String         @id @db.Uuid
  email              String         @unique
  phone              String         @unique
  fullName           String
  passwordHash       String?
  roles              UserRoleCode[]
  userType           UserType
  accountStatus      AccountStatus
  isEnabled          Boolean
  activationIssuedAt DateTime?      @db.Timestamptz(6)
  lastLoginAt        DateTime?      @db.Timestamptz(6)
  createdAt          DateTime       @db.Timestamptz(6)
  updatedAt          DateTime       @db.Timestamptz(6)

  slyderProfile                  SlyderProfile?
  employeeProfile                EmployeeProfile?
  approvedApplications           SlyderProfile[]                @relation("SlyderProfileApprovedBy")
  reviewedApplications           SlyderApplication[]            @relation("SlyderApplicationReviewedBy")
  employeeApplications           EmployeeApplication[]          @relation("EmployeeApplicationLinkedUser")
  merchantTeamMemberships        MerchantTeamMember[]
  managedEmployees               EmployeeProfile[]              @relation("EmployeeProfileManager")
  publishedEmployeeAnnouncements EmployeeAnnouncement[]         @relation("EmployeeAnnouncementPublishedBy")
  triggeredNotifications         NotificationRecord[]           @relation("NotificationTriggeredBy")
  sessions                       SessionRecord[]
  activationTokens               ActivationToken[]
  otpChallenges                  OtpChallenge[]
  residentialLeads               ResidentialLead[]
  residentialDispatchRequests    ResidentialDispatchRequest[]
  residentialWallet              ResidentialWallet?
  residentialWalletTransactions  ResidentialWalletTransaction[]
  residentialAccountProfile      ResidentialAccountProfile?
  reviewedKycProfiles            ResidentialAccountProfile[]    @relation("KycReviewedBy")
}

model SlyderApplication {
  id                      String            @id @db.Uuid
  applicationCode         String            @unique
  fullName                String
  email                   String
  phone                   String
  dateOfBirth             DateTime          @db.Date
  parish                  String
  address                 String
  trn                     String
  emergencyContactName    String
  emergencyContactPhone   String
  courierType             CourierType
  workTypePreference      String
  availability            String
  preferredZones          String[]
  deliveryTypePreferences String[]
  maxTravelComfort        String
  peakHours               String
  smartphoneType          String
  whatsappNumber          String
  gpsConfirmed            Boolean
  internetConfirmed       Boolean
  readinessAnswers        Json
  agreementsAccepted      Json
  applicationStatus       ApplicationStatus
  accountStatus           AccountStatus
  operationalStatus       OperationalStatus
  readinessStatus         ReadinessStatus
  reviewNotes             String?
  rejectionReason         String?
  requestedDocumentNotes  String?
  requestedDocumentTypes  DocumentType[]
  submittedAt             DateTime          @db.Timestamptz(6)
  reviewedAt              DateTime?         @db.Timestamptz(6)
  reviewedBy              String?           @db.Uuid
  linkedUserId            String?           @db.Uuid
  linkedSlyderProfileId   String?           @db.Uuid
  createdAt               DateTime          @db.Timestamptz(6)
  updatedAt               DateTime          @db.Timestamptz(6)

  reviewer        User?                       @relation("SlyderApplicationReviewedBy", fields: [reviewedBy], references: [id])
  vehicle         SlyderApplicationVehicle?
  documents       SlyderApplicationDocument[]
  slyderProfile   SlyderProfile?
  publicReferrals PublicSlyderReferral[]

  @@index([applicationStatus, createdAt(sort: Desc)])
  @@index([linkedUserId])
  @@index([linkedSlyderProfileId])
}

model SlyderApplicationVehicle {
  id                 String    @id @db.Uuid
  applicationId      String    @unique @db.Uuid
  make               String?
  model              String?
  year               String?
  color              String?
  plateNumber        String?
  registrationExpiry DateTime? @db.Date
  insuranceExpiry    DateTime? @db.Date
  fitnessExpiry      DateTime? @db.Date
  createdAt          DateTime  @db.Timestamptz(6)
  updatedAt          DateTime  @db.Timestamptz(6)

  application SlyderApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model SlyderApplicationDocument {
  id                 String                     @id @db.Uuid
  applicationId      String                     @db.Uuid
  type               DocumentType
  fileUrl            String
  storageKey         String
  fileName           String
  mimeType           String
  verificationStatus DocumentVerificationStatus
  rejectionReason    String?
  uploadedAt         DateTime                   @db.Timestamptz(6)
  reviewedAt         DateTime?                  @db.Timestamptz(6)
  reviewedBy         String?                    @db.Uuid

  application SlyderApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type])
  @@index([verificationStatus, type])
}

model SlyderProfile {
  id                              String            @id @db.Uuid
  userId                          String            @unique @db.Uuid
  applicationId                   String            @unique @db.Uuid
  coverageZoneId                  String?           @db.Uuid
  displayName                     String
  phone                           String
  email                           String
  courierType                     CourierType
  onboardingStatus                OnboardingStatus
  readinessStatus                 ReadinessStatus
  operationalStatus               OperationalStatus
  accountStatus                   AccountStatus
  contractAccepted                Boolean
  contractAcceptedAt              DateTime?         @db.Timestamptz(6)
  vehicleVerified                 Boolean
  payoutSetupComplete             Boolean
  profileComplete                 Boolean
  trainingComplete                Boolean
  permissionsComplete             Boolean
  requiredAgreementsAccepted      Boolean
  setupCompletedAt                DateTime?         @db.Timestamptz(6)
  trainingAcknowledgedAt          DateTime?         @db.Timestamptz(6)
  activatedAt                     DateTime?         @db.Timestamptz(6)
  canGoOnline                     Boolean
  canReceiveOrders                Boolean
  profileConfirmed                Boolean
  vehicleConfirmed                Boolean
  payoutConfigured                Boolean
  legalAccepted                   Boolean
  locationPermissionConfirmed     Boolean
  notificationPermissionConfirmed Boolean
  equipmentConfirmed              Boolean
  trainingAcknowledged            Boolean
  emergencyContactConfirmed       Boolean
  readinessChecklistStatus        ReadinessStatus
  readinessChecklistCreatedAt     DateTime?         @db.Timestamptz(6)
  readinessChecklistUpdatedAt     DateTime?         @db.Timestamptz(6)
  approvedAt                      DateTime          @db.Timestamptz(6)
  approvedBy                      String            @db.Uuid
  createdAt                       DateTime          @db.Timestamptz(6)
  updatedAt                       DateTime          @db.Timestamptz(6)

  user            User                   @relation(fields: [userId], references: [id])
  application     SlyderApplication      @relation(fields: [applicationId], references: [id])
  coverageZone    CoverageZone?          @relation(fields: [coverageZoneId], references: [id])
  approver        User                   @relation("SlyderProfileApprovedBy", fields: [approvedBy], references: [id])
  notifications   NotificationRecord[]
  publicReferrals PublicSlyderReferral[]

  @@index([coverageZoneId])
  @@index([operationalStatus, readinessStatus])
}

model StatusHistory {
  id          String     @id @db.Uuid
  entityType  EntityType
  entityId    String     @db.Uuid
  eventType   String
  actorUserId String?    @db.Uuid
  actorLabel  String?
  metadata    Json?
  createdAt   DateTime   @db.Timestamptz(6)

  @@index([entityType, entityId, createdAt(sort: Desc)])
}

model ActivationToken {
  id              String                @id @db.Uuid
  userId          String                @db.Uuid
  tokenHash       String                @unique
  deliveryChannel DeliveryChannel
  status          ActivationTokenStatus
  issuedAt        DateTime?             @db.Timestamptz(6)
  expiresAt       DateTime              @db.Timestamptz(6)
  consumedAt      DateTime?             @db.Timestamptz(6)
  createdAt       DateTime              @db.Timestamptz(6)
  updatedAt       DateTime?             @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model OtpChallenge {
  id         String    @id @db.Uuid
  userId     String    @db.Uuid
  codeHash   String
  expiresAt  DateTime  @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model SessionRecord {
  id        String         @id @db.Uuid
  userId    String         @db.Uuid
  roles     UserRoleCode[]
  createdAt DateTime       @db.Timestamptz(6)
  expiresAt DateTime       @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model NotificationTemplate {
  id                String                @id @db.Uuid
  key               String
  name              String
  actorType         NotificationActorType
  eventType         String
  channel           NotificationChannel
  subject           String?
  bodyTemplate      String
  plainTextTemplate String?
  isActive          Boolean
  version           String
  locale            String?
  description       String?
  createdAt         DateTime              @db.Timestamptz(6)
  updatedAt         DateTime              @db.Timestamptz(6)

  notifications NotificationRecord[]

  @@unique([key, version, channel])
  @@index([actorType, eventType, channel, isActive])
}

model NotificationTriggerEvent {
  id                String                    @id @db.Uuid
  eventKey          String                    @unique
  relatedEntityType RelatedEntityType?
  relatedEntityId   String?                   @db.Uuid
  actorType         NotificationActorType?
  actorId           String?                   @db.Uuid
  payload           Json?
  status            NotificationTriggerStatus
  errorMessage      String?
  createdAt         DateTime                  @db.Timestamptz(6)
  updatedAt         DateTime                  @db.Timestamptz(6)

  notifications NotificationRecord[]

  @@index([status, createdAt])
}

model NotificationRecord {
  id                String                 @id @db.Uuid
  templateId        String?                @db.Uuid
  templateKey       String?
  triggerEventId    String?                @db.Uuid
  triggerEventKey   String?
  dedupeKey         String?
  actorType         NotificationActorType?
  actorId           String?                @db.Uuid
  relatedEntityType RelatedEntityType?
  relatedEntityId   String?                @db.Uuid
  userId            String?                @db.Uuid
  applicationId     String?                @db.Uuid
  slyderProfileId   String?                @db.Uuid
  channel           NotificationChannel
  template          String
  recipient         String?
  recipientName     String?
  status            NotificationStatus?
  providerName      String?
  providerMessageId String?
  subjectSnapshot   String?
  bodySnapshot      String?
  variablesSnapshot Json?
  failureReason     String?
  resentFromId      String?                @db.Uuid
  retryCount        Int?
  lastAttemptAt     DateTime?              @db.Timestamptz(6)
  sentAt            DateTime?              @db.Timestamptz(6)
  deliveredAt       DateTime?              @db.Timestamptz(6)
  createdBySystem   Boolean?
  triggeredByUserId String?                @db.Uuid
  metadata          Json?
  payload           Json
  createdAt         DateTime               @db.Timestamptz(6)
  updatedAt         DateTime?              @db.Timestamptz(6)

  templateRef     NotificationTemplate?     @relation(fields: [templateId], references: [id])
  triggerEvent    NotificationTriggerEvent? @relation(fields: [triggerEventId], references: [id])
  resentFrom      NotificationRecord?       @relation("NotificationResendChain", fields: [resentFromId], references: [id])
  resentChildren  NotificationRecord[]      @relation("NotificationResendChain")
  triggeredByUser User?                     @relation("NotificationTriggeredBy", fields: [triggeredByUserId], references: [id])
  slyderProfile   SlyderProfile?            @relation(fields: [slyderProfileId], references: [id])

  @@unique([dedupeKey])
  @@index([actorType, actorId, createdAt(sort: Desc)])
  @@index([applicationId, createdAt(sort: Desc)])
  @@index([slyderProfileId, createdAt(sort: Desc)])
}

model SupportConversation {
  id                     String                    @id @db.Uuid
  channel                SupportChannel
  domain                 SupportDomain
  status                 SupportConversationStatus
  priority               SupportPriority
  subject                String
  externalProvider       String?
  externalConversationId String?
  externalTicketId       String?
  userId                 String?                   @db.Uuid
  merchantId             String?                   @db.Uuid
  slyderProfileId        String?                   @db.Uuid
  employeeProfileId      String?                   @db.Uuid
  referrerAccountId      String?
  assignedTeam           String?
  assignedAgentId        String?                   @db.Uuid
  lastMessageAt          DateTime?                 @db.Timestamptz(6)
  resolvedAt             DateTime?                 @db.Timestamptz(6)
  closedAt               DateTime?                 @db.Timestamptz(6)
  createdAt              DateTime                  @db.Timestamptz(6)
  updatedAt              DateTime                  @db.Timestamptz(6)

  messages         SupportMessage[]
  contextSnapshots SupportContextSnapshot[]
  handoffs         SupportHandoff[]
  events           SupportEvent[]

  @@index([domain, status, priority, createdAt(sort: Desc)])
  @@index([merchantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([externalTicketId])
}

model SupportMessage {
  id                String            @id @db.Uuid
  conversationId    String            @db.Uuid
  senderType        SupportSenderType
  senderId          String?
  body              String
  messageFormat     String
  externalMessageId String?
  aiGenerated       Boolean
  metadata          Json?
  createdAt         DateTime          @db.Timestamptz(6)

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Asc)])
}

model SupportContextSnapshot {
  id             String   @id @db.Uuid
  conversationId String   @db.Uuid
  contextType    String
  payload        Json
  createdAt      DateTime @db.Timestamptz(6)

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
}

model SupportHandoff {
  id                String   @id @db.Uuid
  conversationId    String   @db.Uuid
  reason            String
  summary           String
  recommendedTeam   String
  confidenceScore   Float?
  acceptedByAgentId String?  @db.Uuid
  createdAt         DateTime @db.Timestamptz(6)

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([recommendedTeam])
}

model SupportEvent {
  id             String           @id @db.Uuid
  conversationId String           @db.Uuid
  eventType      SupportEventType
  actorType      String
  actorId        String?
  notes          String?
  metadata       Json?
  createdAt      DateTime         @db.Timestamptz(6)

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, eventType, createdAt(sort: Desc)])
}

model SupportKnowledgeArticle {
  id        String        @id @db.Uuid
  domain    SupportDomain
  audience  String[]
  title     String
  slug      String        @unique
  summary   String?
  content   String
  tags      String[]
  published Boolean
  createdAt DateTime      @db.Timestamptz(6)
  updatedAt DateTime      @db.Timestamptz(6)

  @@index([domain, published])
}

model CoverageZone {
  id                   String               @id @db.Uuid
  name                 String
  parish               String
  requiredReadySlyders Int
  merchantAvailability MerchantAvailability
  estimatedLaunchLabel String
  isLive               Boolean
  isPaused             Boolean
  notes                String?
  createdAt            DateTime             @db.Timestamptz(6)
  updatedAt            DateTime             @db.Timestamptz(6)

  slyderProfiles SlyderProfile[]

  @@unique([name, parish])
}

model MerchantInterest {
  id                   String                  @id @db.Uuid
  companyName          String
  contactName          String
  email                String
  phone                String
  whatsappNumber       String?
  businessType         String
  deliveryVolume       String
  coverageNeeds        String
  goals                String
  parish               String?
  town                 String?
  zoneId               String?                 @db.Uuid
  zoneName             String?
  operationalNotes     String?
  lifecycleStatus      MerchantLifecycleStatus
  linkedMerchantUserId String?                 @db.Uuid
  createdAt            DateTime                @db.Timestamptz(6)
  updatedAt            DateTime                @db.Timestamptz(6)

  @@index([lifecycleStatus, createdAt(sort: Desc)])
}

model MerchantLead {
  id                     String                @id @db.Uuid
  businessName           String
  contactName            String
  phone                  String
  email                  String
  parish                 String
  town                   String
  category               String
  instagramHandle        String?
  website                String?
  orderChannels          Json
  averageDailyOrders     String?
  currentDeliveryMethod  String?
  preferredStartTimeline String?
  productIntent          MerchantProductIntent
  status                 MerchantLeadStatus
  notes                  String?
  createdAt              DateTime              @db.Timestamptz(6)
  updatedAt              DateTime              @db.Timestamptz(6)

  applications MerchantApplication[]

  @@index([status, createdAt(sort: Desc)])
  @@index([productIntent, createdAt(sort: Desc)])
  @@index([email, createdAt(sort: Desc)])
  @@index([phone, createdAt(sort: Desc)])
}

model MerchantApplication {
  id                                     String                              @id @db.Uuid
  merchantLeadId                         String                              @db.Uuid
  onboardingTrack                        MerchantOnboardingTrack
  storeName                              String?
  logoUrl                                String?
  heroBannerUrl                          String?
  heroBannerPosition                     String?
  businessDescription                    String?
  category                               String?
  pickupAddress                          String?
  serviceAreas                           Json
