enum ReferralReferrerType {
  PUBLIC
  SLYDER
  ADMIN
  MERCHANT
}

enum ReferralStatus {
  PENDING
  LEAD_CAPTURED
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  APPROVED
  ACTIVATED
  LIVE
  REWARD_ACTIVE
  PARTIAL_PAID
  PAID_OUT
  CANCELLED
  REJECTED
  EXPIRED
}

enum ReferralPayoutStatus {
  PENDING
  EARNED
  APPROVED
  PAID
  CANCELLED
}

enum ReferralPayoutMethod {
  CASH
  BANK_TRANSFER
  WALLET
  LYNK
  OTHER
}

model SlyderReferral {
  id                    String               @id @default(cuid())
  referralCode          String               @unique
  referralLink          String?
  referrerType          ReferralReferrerType @default(PUBLIC)
  referrerName          String
  referrerEmail         String?
  referrerWhatsapp      String
  referrerSlyderId      String?
  referredFirstName     String?
  referredLastName      String?
  referredEmail         String?
  referredWhatsapp      String?
  referredLeadId        String?
  referredApplicationId String?
  referredSlyderId      String?
  status                ReferralStatus       @default(PENDING)
  totalRewardAmount     Int                  @default(5000)
  rewardCurrency        String               @default("JMD")
  paidAmount            Int                  @default(0)
  remainingAmount       Int                  @default(5000)
  rentCyclesRequired    Int                  @default(5)
  rentCyclesCompleted   Int                  @default(0)
  qualificationNotes    String?
  adminNotes            String?
  agreementAccepted     Boolean              @default(false)
  agreementVersion      String?
  agreementAcceptedAt   DateTime?
  agreementIpAddress    String?
  agreementUserAgent    String?
  firstRentPaidAt       DateTime?
  rewardActivatedAt     DateTime?
  paidOutAt             DateTime?
  expiresAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  payouts SlyderReferralPayout[]

  @@index([referralCode])
  @@index([referrerWhatsapp])
  @@index([referredWhatsapp])
  @@index([status])
  @@index([referrerSlyderId])
  @@index([referredSlyderId])
}

model SlyderReferralPayout {
  id                String                @id @default(cuid())
  referralId        String
  cycleNumber       Int
  rentAmount        Int                   @default(2000)
  payoutAmount      Int                   @default(1000)
  currency          String                @default("JMD")
  status            ReferralPayoutStatus  @default(PENDING)
  payoutMethod      ReferralPayoutMethod?
  externalReference String?
  adminNotes        String?
  earnedAt          DateTime?
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  referral SlyderReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@unique([referralId, cycleNumber])
  @@index([status])
  @@index([referralId])
}
