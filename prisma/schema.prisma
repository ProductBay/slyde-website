model SlyderQualification {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  hasVehicle         Boolean?
  hasSmartphone      Boolean?
  usesWhatsapp       Boolean?
  hasDataAccess      Boolean?
  availableWeekly    Boolean?
  preferredZones     String[]
  preferredSchedule  String?
  deliveryExperience String?
  readinessLevel     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lead SlyderLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model SlyderLeadPushSubscription {
  id           String    @id @default(cuid())
  leadId       String
  endpoint     String    @unique
  p256dh       String
  auth         String
  userAgent    String?
  isActive     Boolean   @default(true)
  failureCount Int       @default(0)
  lastSeenAt   DateTime  @default(now())
  lastSentAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lead SlyderLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, isActive])
  @@index([isActive, updatedAt])
}

enum SlyderLeadPostCategory {
  ANNOUNCEMENT
  PROMOTION
  LAUNCH_UPDATE
  REMINDER
  EDUCATION
}

model SlyderLeadPost {
  id          String                 @id @default(cuid())
  title       String
  body        String
  category    SlyderLeadPostCategory @default(ANNOUNCEMENT)
  imageUrl    String?
  imageCropX  Int                    @default(50)
  imageCropY  Int                    @default(50)
