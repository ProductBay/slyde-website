}

model ResidentialAccountProfile {
  id                String            @id @db.Uuid
  userId            String            @unique @db.Uuid
  trn               String
  idType            ResidentIdType
  idDocumentPath    String
  kycStatus         ResidentKycStatus @default(pending_review)
