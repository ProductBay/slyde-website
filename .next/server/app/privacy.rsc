c:[["$","title","0",{"children":"Privacy"}],["$","meta","1",{"name":"description","content":"Read the SLYDE public website privacy policy."}],["$","link","2",{"rel":"canonical","href":"https://slyde.app/privacy"}],["$","meta","3",{"property":"og:title","content":"Privacy"}],["$","meta","4",{"property":"og:description","content":"Read the SLYDE public website privacy policy."}],["$","meta","5",{"property":"og:url","content":"https://slyde.app/privacy"}],["$","meta","6",{"property":"og:site_name","content":"SLYDE"}],["$","meta","7",{"property":"og:type","content":"website"}],["$","meta","8",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","9",{"name":"twitter:title","content":"Privacy"}],["$","meta","10",{"name":"twitter:description","content":"Read the SLYDE public website privacy policy."}],["$","link","11",{"rel":"icon","href":"/icon.svg?abfc86d0c3fc8624","type":"image/svg+xml","sizes":"any"}]]
5:["$","section",null,{"className":"mx-auto max-w-reading px-4 py-16 sm:px-6 lg:px-8","children":[["$","p",null,{"className":"eyebrow-badge border-sky-100 bg-sky-50 text-sky-700","children":"Legal Document"}],["$","h1",null,{"className":"mt-5 text-4xl font-semibold tracking-tight text-slate-950","children":"Website Privacy Policy"}],["$","div",null,{"className":"mt-4 flex flex-wrap gap-3 text-sm text-slate-500","children":[["$","span",null,{"children":["Version ","2026.03.19"]}],["$","span",null,{"children":["Published ","19/03/2026"]}]]}],["$","p",null,{"className":"mt-6 text-base leading-8 text-slate-600","children":"How SLYDE handles information submitted through the public website."}],["$","div",null,{"className":"mt-10 space-y-6 text-sm leading-8 text-slate-600","children":[["$","p","97cea960-f59d-4423-af09-e38424f8d3e6-0",{"children":"SLYDE collects personal, business, and inquiry information submitted through this website to review applications, respond to contact requests, evaluate partnerships, and support future logistics operations."}],["$","p","97cea960-f59d-4423-af09-e38424f8d3e6-1",{"children":"Slyder application data can include identification details, contact information, courier type, vehicle details, document metadata, availability, and readiness information. This data is used to assess whether an applicant can move into review, approval, account activation, and later work eligibility."}],["$","p","97cea960-f59d-4423-af09-e38424f8d3e6-2",{"children":"Business and API inquiry data is used to evaluate service fit, partnership opportunity, and future integration planning. Information may be retained for operational follow-up, legal compliance, internal review, and platform onboarding."}],["$","p","97cea960-f59d-4423-af09-e38424f8d3e6-3",{"children":"As backend services are connected, SLYDE may use secure storage, access controls, verification tools, and audit workflows to protect submitted information and manage the approval-to-login lifecycle responsibly."}]]}]]}]
